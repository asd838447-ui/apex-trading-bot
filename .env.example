# APEX Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/apex_trading
REDIS_URL=redis://localhost:6379/0

# === Authentication ===
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# === Demo Mode ===
# Set to "true" to run with simulated data (no API keys needed)
DEMO_MODE=true

# === Binance API (required for live trading) ===
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# === Glassnode API (for on-chain analytics) ===
GLASSNODE_API_KEY=

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Security ===
VAULT_ENCRYPTION_KEY=

# === Server ===
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
